{
  "strategy_name": "ADXVolumeBreakout",
  "description": "A breakout strategy that enters when price breaks above/below a 20-period high/low while ADX indicates strong trend (above 25) and volume confirms the breakout (exceeds 10-period average). Exits use a fixed 2:1 risk-reward ratio based on the breakout range.",
  "indicators": [
    {
      "name": "adx",
      "library": "pandas_ta",
      "params": {
        "length": 14
      }
    },
    {
      "name": "highest",
      "library": "pandas_ta",
      "params": {
        "length": 80
      }
    },
    {
      "name": "lowest",
      "library": "pandas_ta",
      "params": {
        "length": 80
      }
    },
    {
      "name": "sma",
      "library": "pandas_ta",
      "params": {
        "length": 40
      }
    }
  ],
  "entry_long": {
    "conditions": [
      "close > highest(high, 80)[-1]",
      "adx(14) > 25",
      "volume > sma(volume, 40)[-1]"
    ],
    "logic": "ALL conditions must be true (AND)"
  },
  "entry_short": {
    "conditions": [
      "close < lowest(low, 80)[-1]",
      "adx(14) > 25",
      "volume > sma(volume, 40)[-1]"
    ],
    "logic": "ALL conditions must be true (AND)"
  },
  "exit_long": {
    "conditions": [],
    "stop_loss": "Entry price - (highest(high, 80)[-1] - lowest(low, 80)[-1]) * 0.5",
    "take_profit": "Entry price + (highest(high, 80)[-1] - lowest(low, 80)[-1]) * 1.0"
  },
  "exit_short": {
    "conditions": [],
    "stop_loss": "Entry price + (highest(high, 80)[-1] - lowest(low, 80)[-1]) * 0.5",
    "take_profit": "Entry price - (highest(high, 80)[-1] - lowest(low, 80)[-1]) * 1.0"
  },
  "position_sizing": "fixed 100% equity per trade (backtesting.py default)",
  "parameters": {
    "adx_threshold": 25,
    "lookback_period": 80,
    "volume_sma_period": 40,
    "risk_multiplier": 0.5,
    "reward_multiplier": 1.0
  },
  "expected_trade_frequency": "15-25 trades per 1000 candles",
  "notes": "Using 80-period (20 days * 4 periods per hour) high/low for 15-minute candles. Volume SMA uses 40 periods (10 days). Stop loss is half the breakout range, take profit is full range, achieving 2:1 RR. Ensure ADX calculation uses Wilder's smoothing as in pandas_ta default."
}